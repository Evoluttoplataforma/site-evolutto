---
import Base from '../layouts/Base.astro';
import Logo from '../components/Logo.astro';
---

<Base title="Design System — Evolutto">
  <!-- Animações/efeitos extraídos das referências (border beam, marquee, flashlight, loaders) -->
  <style is:global>
    @keyframes ds-spin { to { transform: rotate(360deg); } }
    @keyframes ds-radar { 0% { transform: scale(0.5); opacity: 1; } 100% { transform: scale(2.6); opacity: 0; } }
    @keyframes ds-ring-dash {
      0% { stroke-dasharray: 1, 200; stroke-dashoffset: 0; }
      50% { stroke-dasharray: 90, 200; stroke-dashoffset: -35px; }
      100% { stroke-dasharray: 90, 200; stroke-dashoffset: -124px; }
    }
    @keyframes ds-dash-draw { 0% { stroke-dashoffset: 100; } 50% { stroke-dashoffset: 0; } 100% { stroke-dashoffset: -100; } }
    @keyframes ds-scroll-left { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    @keyframes ds-rotate-beam { to { transform: rotate(360deg); } }

    .marquee-content { animation: ds-scroll-left 30s linear infinite; }
    .marquee-mask {
      -webkit-mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
      mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);
    }

    .btn-beam-container { position: relative; }
    .btn-beam-container .beam-border {
      position: absolute; inset: -2px; border-radius: 9999px; pointer-events: none; opacity: 0;
      background: conic-gradient(from 0deg at 50% 50%, transparent 0deg, #3363ff 60deg, transparent 120deg);
      animation: ds-rotate-beam 2.5s linear infinite; transition: opacity .3s;
    }
    .btn-beam-container:hover .beam-border { opacity: 1; }

    .flashlight-card { position: relative; overflow: hidden; }
    .flashlight-card::before {
      content: ""; position: absolute; inset: 0; border-radius: inherit; opacity: 0; pointer-events: none; transition: opacity .4s; z-index: 1;
      background: radial-gradient(500px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(51,99,255,0.16), transparent 40%);
    }
    .flashlight-card .flashlight-border {
      position: absolute; inset: 0; border-radius: inherit; padding: 1px; opacity: 0; pointer-events: none; transition: opacity .4s;
      background: radial-gradient(400px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(51,99,255,0.8), transparent 40%);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor; mask-composite: exclude;
    }
    .flashlight-card:hover::before, .flashlight-card:hover .flashlight-border { opacity: 1; }

    .rotator-card { position: absolute; inset: 2rem; transition: all .6s cubic-bezier(0.4, 0, 0.2, 1); }
    .feature-btn.active-feature { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12) !important; }

    @keyframes ds-shimmer { 100% { transform: translateX(100%); } }
    .skeleton { position: relative; overflow: hidden; background: rgba(0,0,0,0.06); }
    .skeleton::after { content: ""; position: absolute; inset: 0; transform: translateX(-100%); background: linear-gradient(90deg, transparent, rgba(0,0,0,0.05), transparent); animation: ds-shimmer 1.5s infinite; }
  </style>
  <script>
    // Flashlight: segue o cursor (define --mouse-x/--mouse-y por card)
    const cards = document.querySelectorAll('.flashlight-card');
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        (card as HTMLElement).style.setProperty('--mouse-x', e.clientX - r.left + 'px');
        (card as HTMLElement).style.setProperty('--mouse-y', e.clientY - r.top + 'px');
      });
    });

    // Feature switcher + rotator card
    const featBtns = Array.from(document.querySelectorAll('.feature-btn'));
    const rotCards = Array.from(document.querySelectorAll('.rotator-card'));
    let rotCur = 0;
    function setRot(i: number) {
      rotCur = (i + rotCards.length) % rotCards.length;
      rotCards.forEach((c, n) => {
        const el = c as HTMLElement;
        el.style.opacity = n === rotCur ? '1' : '0';
        el.style.transform = n === rotCur ? 'scale(1)' : 'scale(0.92)';
        el.style.pointerEvents = n === rotCur ? 'auto' : 'none';
      });
      featBtns.forEach((b, n) => b.classList.toggle('active-feature', n === rotCur));
    }
    featBtns.forEach((b, n) => b.addEventListener('click', () => setRot(n)));
    document.querySelector('[data-rot-prev]')?.addEventListener('click', () => setRot(rotCur - 1));
    document.querySelector('[data-rot-next]')?.addEventListener('click', () => setRot(rotCur + 1));
    if (rotCards.length) setRot(0);
  </script>

  <!-- Main Container -->
  <main
    class="w-full max-w-[1400px] bg-[#F3F3F1] rounded-[2.5rem] shadow-2xl relative flex flex-col overflow-hidden"
  >
    <!-- Design System Navigation -->
    <header
      class="sticky top-0 z-50 bg-[#F3F3F1]/95 backdrop-blur-sm border-b border-gray-200/50"
    >
      <nav class="flex lg:px-12 pt-6 pr-8 pb-6 pl-8 items-center justify-between">
        <!-- Logo oficial Evolutto -->
        <Logo variant="dark" />
        <!-- Design System Nav Links -->
        <div class="hidden lg:flex items-center gap-6">
          <a class="text-[0.7rem] font-medium uppercase tracking-[0.2em] text-gray-500 hover:text-black transition-colors" href="#hero">Hero</a>
          <a class="text-[0.7rem] font-medium uppercase tracking-[0.2em] text-gray-500 hover:text-black transition-colors" href="#typography">Tipografia</a>
          <a class="text-[0.7rem] font-medium uppercase tracking-[0.2em] text-gray-500 hover:text-black transition-colors" href="#colors">Cores</a>
          <a class="text-[0.7rem] font-medium uppercase tracking-[0.2em] text-gray-500 hover:text-black transition-colors" href="#components">Componentes</a>
          <a class="text-[0.7rem] font-medium uppercase tracking-[0.2em] text-gray-500 hover:text-black transition-colors" href="#layout">Layout</a>
          <a class="text-[0.7rem] font-medium uppercase tracking-[0.2em] text-gray-500 hover:text-black transition-colors" href="#motion">Motion</a>
          <a class="text-[0.7rem] font-medium uppercase tracking-[0.2em] text-gray-500 hover:text-black transition-colors" href="#icons">Ícones</a>
        </div>
      </nav>
    </header>

    <!-- 0) Hero Section (Clone da estrutura, texto adaptado) -->
    <section id="hero" class="grid grid-cols-1 lg:grid-cols-2 lg:min-h-[70vh]">
      <!-- Left Column: Typography -->
      <div class="relative flex flex-col justify-center px-8 pb-12 pt-4 lg:px-12 xl:px-20 z-10">
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-6">
          Design System &amp; Pattern Library
        </p>
        <div class="relative mb-6">
          <h1 class="text-7xl lg:text-8xl xl:text-9xl font-semibold tracking-tighter leading-[0.85] text-[#0A0A0A]">
            DESIGN<br />SYSTEM
          </h1>
          <div class="absolute -bottom-4 left-0 lg:left-2 inline-flex items-center gap-2 bg-evolutto-black text-white px-4 py-2 rounded-full transform -rotate-2 hover:rotate-0 transition-transform cursor-default z-20 shadow-xl">
            <span class="text-[0.65rem] font-bold uppercase tracking-widest">Componentes &amp; Padrões</span>
          </div>
        </div>
        <div class="mt-8 max-w-lg">
          <h2 class="text-xl font-medium tracking-tight text-gray-900 mb-4 leading-snug">
            Um guia completo da <span class="text-evolutto-blue">linguagem visual</span> e dos componentes reutilizáveis do site da Evolutto.
          </h2>
          <p class="text-base text-gray-500 leading-relaxed font-normal mb-8">
            Documenta tipografia, cores, componentes, layouts e interações. Todos os exemplos usam as classes e estilos exatos do design — tokenizados com a marca Evolutto (Manual 2023).
          </p>
        </div>
      </div>
      <!-- Right Column: Visual (gradiente oficial + glow) -->
      <div class="relative h-[50vh] lg:h-auto overflow-hidden lg:rounded-tl-[4rem] group bg-evolutto-gradient">
        <div class="absolute inset-0 bg-gradient-to-t to-transparent from-evolutto-black/60"></div>
        <!-- Ambient glow -->
        <div class="absolute top-1/4 right-1/4 w-72 h-72 bg-evolutto-blue/40 rounded-full blur-[100px] pointer-events-none"></div>
        <!-- Floating Elements -->
        <div class="absolute top-1/2 left-8 lg:left-12 transform -translate-y-1/2">
          <div class="flex items-center justify-center w-12 h-12 rounded-full border border-white/30 backdrop-blur-md text-white/80 animate-pulse">
            <i class="w-5 h-5" data-lucide="cpu"></i>
          </div>
        </div>
        <div class="absolute bottom-12 right-8 lg:right-12">
          <div class="px-4 py-2 rounded-full border border-white/40 bg-white/10 backdrop-blur-xl text-white text-[0.6rem] font-semibold uppercase tracking-widest hover:bg-white/20 transition-colors cursor-default">
            #produtize
          </div>
        </div>
        <div class="transform backdrop-blur-[2px] w-16 h-16 border-white/50 border rounded-lg mx-28 absolute top-1/3 right-1/4 rotate-12"></div>
      </div>
    </section>

    <!-- 1) Typography Section -->
    <section id="typography" class="lg:px-16 xl:px-24 pt-16 pr-8 pb-20 pl-8">
      <div class="flex flex-col gap-2 mb-16">
        <span class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400">Tipografia</span>
        <h2 class="text-3xl font-medium tracking-tight text-gray-900">Escala &amp; Hierarquia — Inter</h2>
      </div>

      <div class="space-y-12">
        <!-- Heading 1 -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Heading 1</p>
            <h1 class="text-7xl lg:text-8xl xl:text-9xl font-semibold tracking-tighter leading-[0.85] text-[#0A0A0A]">
              PRODUTIZE
            </h1>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-4">
            <div>112px / 95px</div>
            <div class="text-xs mt-1">lg: 128px</div>
            <div class="text-xs">xl: 144px</div>
          </div>
        </div>

        <!-- Heading 2 -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Heading 2</p>
            <h2 class="text-xl font-medium tracking-tight text-gray-900 leading-snug">
              Software feito para escalar consultorias
            </h2>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-2">20px / 28px</div>
        </div>

        <!-- Heading 3 (Large / Dark) -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Heading 3 (Large / Dark)</p>
            <h3 class="text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight text-white leading-[1.15] bg-evolutto-black px-6 py-4 rounded-lg">
              Inovação para consultorias de todos os tamanhos
            </h3>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-2">
            <div>30px / 35px</div>
            <div class="text-xs mt-1">md: 36px</div>
            <div class="text-xs">lg: 48px</div>
          </div>
        </div>

        <!-- Heading 3 (Título de seção) -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Heading 3 (Título de seção)</p>
            <h3 class="text-4xl lg:text-5xl font-medium tracking-tight text-gray-900">
              Pilares da consultoria eficaz
            </h3>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-2">
            <div>36px / 40px</div>
            <div class="text-xs mt-1">lg: 48px</div>
          </div>
        </div>

        <!-- Section Label -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Label de Seção</p>
            <span class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400">Texto de Label</span>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-1">10.4px / 16px</div>
        </div>

        <!-- Navigation Link -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Link de Navegação</p>
            <a class="text-[0.7rem] font-medium uppercase tracking-[0.2em] text-gray-500 hover:text-black transition-colors" href="#">Link de Navegação</a>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-1">11.2px / 16px</div>
        </div>

        <!-- Badge Text (Bold) -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Badge (Bold)</p>
            <span class="text-[0.65rem] font-bold uppercase tracking-widest bg-evolutto-black text-white px-4 py-2 rounded-full">Badge Bold</span>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-1">10.4px / 16px</div>
        </div>

        <!-- Paragraph (Base) -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Parágrafo (Base)</p>
            <p class="text-base text-gray-500 leading-relaxed font-normal">
              Plataforma inteligente 100% web e mobile para digitalização e escala de consultorias, mentorias e processos de implantação de softwares.
            </p>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-2">16px / 24px</div>
        </div>

        <!-- Paragraph (Large) -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Parágrafo (Large)</p>
            <p class="text-lg text-gray-500 leading-relaxed font-normal">
              Automatizamos processos-chave e integramos todas as áreas da sua consultoria, tornando o seu sucesso uma realidade.
            </p>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-2">18px / 28px</div>
        </div>

        <!-- Paragraph (Large Dark) -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1 bg-evolutto-black px-6 py-4 rounded-lg">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Parágrafo (Large Dark)</p>
            <p class="text-lg md:text-2xl font-normal text-gray-400 leading-relaxed">
              Eficiência para todos os tamanhos e segmentos. Usado sobre fundos escuros com tamanho ampliado em telas maiores.
            </p>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-2">
            <div>18px / 28px</div>
            <div class="text-xs mt-1">md: 24px</div>
          </div>
        </div>

        <!-- Small Text -->
        <div class="flex items-start justify-between gap-8 pb-8 border-b border-gray-200">
          <div class="flex-1">
            <p class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400 mb-4">Texto Pequeno</p>
            <p class="text-white font-medium text-sm tracking-wide bg-evolutto-black px-4 py-2 rounded inline-block">Texto pequeno (small)</p>
          </div>
          <div class="text-right text-sm text-gray-500 font-mono pt-1">14px / 20px</div>
        </div>
      </div>
    </section>

    <!-- 2) Colors & Surfaces Section -->
    <section id="colors" class="lg:px-16 xl:px-24 pt-8 pr-8 pb-20 pl-8 bg-white/50">
      <div class="flex flex-col gap-2 mb-16">
        <span class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400">Cores &amp; Superfícies</span>
        <h2 class="text-3xl font-medium tracking-tight text-gray-900">Paleta da Marca &amp; Fundos</h2>
      </div>

      <!-- Cores principais -->
      <div class="mb-12">
        <h3 class="text-2xl font-medium tracking-tight text-gray-900 mb-8">Cores principais</h3>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="flex flex-col gap-2">
            <div class="w-full h-24 rounded-xl bg-white border border-gray-200 shadow-sm"></div>
            <p class="text-sm font-medium text-gray-900">Branco</p>
            <p class="text-xs text-gray-500 font-mono">#ffffff</p>
          </div>
          <div class="flex flex-col gap-2">
            <div class="w-full h-24 rounded-xl bg-evolutto-blue border border-gray-200 shadow-sm"></div>
            <p class="text-sm font-medium text-gray-900">Azul principal</p>
            <p class="text-xs text-gray-500 font-mono">#3363ff</p>
          </div>
          <div class="flex flex-col gap-2">
            <div class="w-full h-24 rounded-xl bg-evolutto-red border border-gray-200 shadow-sm"></div>
            <p class="text-sm font-medium text-gray-900">Vermelho</p>
            <p class="text-xs text-gray-500 font-mono">#d93e3f</p>
          </div>
          <div class="flex flex-col gap-2">
            <div class="w-full h-24 rounded-xl bg-evolutto-black border border-gray-200 shadow-sm"></div>
            <p class="text-sm font-medium text-gray-900">Preto</p>
            <p class="text-xs text-gray-500 font-mono">#222222</p>
          </div>
        </div>
      </div>

      <!-- Cores elementos -->
      <div class="mb-12">
        <h3 class="text-2xl font-medium tracking-tight text-gray-900 mb-8">Cores de elementos</h3>
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="flex flex-col gap-2">
            <div class="w-full h-24 rounded-xl bg-evolutto-purple border border-gray-200 shadow-sm"></div>
            <p class="text-sm font-medium text-gray-900">Roxo</p>
            <p class="text-xs text-gray-500 font-mono">#6959dc</p>
          </div>
          <div class="flex flex-col gap-2">
            <div class="w-full h-24 rounded-xl bg-evolutto-pink border border-gray-200 shadow-sm"></div>
            <p class="text-sm font-medium text-gray-900">Rosa</p>
            <p class="text-xs text-gray-500 font-mono">#db697a</p>
          </div>
          <div class="flex flex-col gap-2">
            <div class="w-full h-24 rounded-xl bg-evolutto-amber border border-gray-200 shadow-sm"></div>
            <p class="text-sm font-medium text-gray-900">Amarelo</p>
            <p class="text-xs text-gray-500 font-mono">#f3c87f</p>
          </div>
        </div>
      </div>

      <!-- Gradiente oficial -->
      <div class="mb-12">
        <h3 class="text-2xl font-medium tracking-tight text-gray-900 mb-8">Gradiente oficial</h3>
        <div class="flex items-center gap-6">
          <div class="flex-1 h-28 rounded-2xl bg-evolutto-gradient border border-gray-200 shadow-sm"></div>
          <div class="max-w-xs">
            <p class="text-sm font-medium text-gray-900">Preto → Azul</p>
            <p class="text-xs text-gray-500 font-mono">#222222 → #2d5eff</p>
            <p class="text-xs text-gray-500 mt-2 leading-relaxed">Transição suave do azul para o preto, preservando traços identificáveis da cor anterior na identidade.</p>
          </div>
        </div>
      </div>

      <!-- Backgrounds / Superfícies -->
      <div>
        <h3 class="text-2xl font-medium tracking-tight text-gray-900 mb-8">Superfícies</h3>
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-24 h-24 rounded-xl bg-[#F3F3F1] border border-gray-200 shadow-sm"></div>
            <div>
              <p class="text-sm font-medium text-gray-900">Fundo da página (container)</p>
              <p class="text-xs text-gray-500 font-mono">bg-[#F3F3F1]</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-24 h-24 rounded-xl bg-stone-300 border border-gray-200 shadow-sm"></div>
            <div>
              <p class="text-sm font-medium text-gray-900">Fundo externo</p>
              <p class="text-xs text-gray-500 font-mono">bg-stone-300</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-24 h-24 rounded-xl bg-evolutto-black border border-gray-200 shadow-sm"></div>
            <div>
              <p class="text-sm font-medium text-gray-900">Seção escura</p>
              <p class="text-xs text-gray-500 font-mono">bg-evolutto-black</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-24 h-24 rounded-xl bg-white/10 backdrop-blur-xl border border-white/40 shadow-sm bg-evolutto-gradient"></div>
            <div>
              <p class="text-sm font-medium text-gray-900">Glass (sobre gradiente)</p>
              <p class="text-xs text-gray-500 font-mono">bg-white/10 backdrop-blur-xl</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3) UI Components Section -->
    <section id="components" class="lg:px-16 xl:px-24 pt-16 pr-8 pb-20 pl-8">
      <div class="flex flex-col gap-2 mb-16">
        <span class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400">Componentes</span>
        <h2 class="text-3xl font-medium tracking-tight text-gray-900">Componentes de UI</h2>
      </div>

      <!-- Buttons -->
      <div class="mb-16">
        <h3 class="text-2xl font-medium tracking-tight text-gray-900 mb-8">Botões</h3>
        <div class="flex flex-wrap items-center gap-6">
          <!-- Primary Button -->
          <button class="flex items-center gap-2 bg-evolutto-black text-white text-[0.7rem] font-medium uppercase tracking-widest px-6 py-3 rounded-full hover:bg-black hover:scale-105 transition-all shadow-lg shadow-gray-300/50">
            Começar <i class="w-3 h-3" data-lucide="arrow-up-right"></i>
          </button>
          <!-- Accent Button (azul Evolutto) -->
          <button class="flex items-center gap-2 bg-evolutto-blue text-white text-[0.7rem] font-medium uppercase tracking-widest px-6 py-3 rounded-full hover:brightness-110 hover:scale-105 transition-all shadow-lg shadow-evolutto-blue/30">
            Quero conhecer <i class="w-3 h-3" data-lucide="arrow-up-right"></i>
          </button>
          <!-- Secondary Button -->
