---
// Layout das páginas do site (marketing) — full-bleed, base clara, Inter + Lucide.
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  keywords?: string[];
  noindex?: boolean;
  jsonLd?: object[];
}
const {
  title = 'Evolutto — Escale sua consultoria e atenda 10x mais clientes',
  description = 'A Evolutto é o ecossistema para digitalizar, produtizar e escalar consultorias: plataforma, método e comunidade para atender mais clientes sem depender da sua presença.',
  ogImage = '/img/founder-platform.png',
  type = 'website',
  keywords,
  noindex = false,
  jsonLd = [],
} = Astro.props;

const SITE = Astro.site ?? new URL('https://www.evolutto.com');
const canonical = new URL(Astro.url.pathname, SITE).toString().replace(/(?<!:)\/{2,}/g, '/');
const img = new URL(ogImage, SITE).toString();

// ===== Entidade (Organization) — em todas as páginas =====
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': new URL('/#organization', SITE).toString(),
  name: 'Evolutto',
  alternateName: 'Evolutto Plataforma',
  url: SITE.toString(),
  logo: new URL('/evolutto-logo-white.png', SITE).toString(),
  description: 'Ecossistema completo para consultores e mentores digitalizarem, produtizarem e escalarem seus serviços — com plataforma, método e comunidade.',
  foundingDate: '2018',
  email: 'contato@evolutto.com',
  areaServed: ['BR', 'PT'],
  knowsAbout: ['Consultoria', 'Escala de consultoria', 'Produtização de serviços', 'Digitalização de consultorias', 'Gestão de projetos de consultoria'],
  address: { '@type': 'PostalAddress', addressLocality: 'Florianópolis', addressRegion: 'SC', addressCountry: 'BR' },
  contactPoint: { '@type': 'ContactPoint', email: 'contato@evolutto.com', contactType: 'customer support', availableLanguage: ['Portuguese'] },
  sameAs: [
    'https://www.instagram.com/evoluttoplataforma/',
    'https://www.linkedin.com/company/evolutto/',
    'https://www.youtube.com/@evolutto',
    'https://www.facebook.com/evoluttoplataforma',
  ],
};
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': new URL('/#website', SITE).toString(),
  url: SITE.toString(),
  name: 'Evolutto',
  inLanguage: 'pt-BR',
  publisher: { '@id': new URL('/#organization', SITE).toString() },
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: 'https://www.evolutto.com/blog/buscar?q={search_term_string}' },
    'query-input': 'required name=search_term_string',
  },
};
// Breadcrumb automático (Home > Página)
const NAMES: Record<string, string> = {
  plataforma: 'Plataforma', consultoria: 'Consultoria', mentorias: 'Mentorias',
  'do-zero-a-escala': 'Do Zero a Escala', bootcamp: 'Bootcamp da Virada',
  'quem-somos': 'Quem somos', indicacao: 'Indicação', carreiras: 'Carreiras',
  suporte: 'Suporte', obrigado: 'Obrigado',
};
const seg = Astro.url.pathname.replace(/^\/|\/$/g, '');
const crumbs = [{ '@type': 'ListItem', position: 1, name: 'Início', item: SITE.toString() }];
if (seg && NAMES[seg]) crumbs.push({ '@type': 'ListItem', position: 2, name: NAMES[seg], item: canonical });
const breadcrumbLd = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: crumbs };

const allLd = [orgLd, websiteLd, ...(crumbs.length > 1 ? [breadcrumbLd] : []), ...jsonLd];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1'} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#3363ff" />
    <link rel="icon" type="image/png" href="/evolutto-logo-white.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Evolutto" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={img} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={img} />

    <link rel="alternate" type="application/rss+xml" title="Blog Evolutto" href="/blog/rss.xml" />

    <!-- Dados estruturados (IA / buscadores) -->
    {allLd.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)}
  </head>
  <body class="bg-white text-gray-900 antialiased overflow-x-hidden">
    <slot />

    <script>
      import {
        createIcons,
        ArrowRight, ArrowUpRight, ArrowLeft, Folder, Cpu, Aperture, Check, ChevronDown,
        ChevronLeft, ChevronRight, Code, Command, FileText, Figma, Framer, Globe, Inbox, Layers, Lock,
        LogOut, Mail, Plus, Scissors, Send, Settings, Shield, Star, Type, Users, Zap,
        Github, BarChart3, Pencil, CirclePlay, Sparkles, Rocket, Gauge, Workflow,
        BadgeCheck, TrendingUp, Menu, Briefcase, GraduationCap, Package, Target,
        BookOpen, MessageCircle, Calendar, CircleCheck, Quote, PlugZap, Phone,
        MapPin, Clock, Building2, Heart, Share2, X, Search,
      } from 'lucide';
      createIcons({
        icons: {
          ArrowRight, ArrowUpRight, ArrowLeft, Folder, Cpu, Aperture, Check, ChevronDown,
          ChevronLeft, ChevronRight, Code, Command, FileText, Figma, Framer, Globe, Inbox, Layers, Lock,
          LogOut, Mail, Plus, Scissors, Send, Settings, Shield, Star, Type, Users, Zap,
          Github, BarChart3, Pencil, CirclePlay, Sparkles, Rocket, Gauge, Workflow,
          BadgeCheck, TrendingUp, Menu, Briefcase, GraduationCap, Package, Target,
          BookOpen, MessageCircle, Calendar, CircleCheck, Quote, PlugZap, Phone,
          MapPin, Clock, Building2, Heart, Share2, X, Search,
        },
      });
    </script>
  </body>
</html>
