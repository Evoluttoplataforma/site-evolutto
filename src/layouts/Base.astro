---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Evolutto' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen flex items-start justify-center lg:p-6 selection:bg-evolutto-blue/30 selection:text-blue-200 text-slate-900 bg-stone-300 pt-4 pr-4 pb-4 pl-4"
  >
    <slot />

    <!-- Lucide Icons — set curado (apenas os usados, tree-shaken) -->
    <script>
      import {
        createIcons,
        ArrowRight, ArrowUpRight, ArrowLeft, Folder, Cpu, Aperture, Check, ChevronDown,
        ChevronLeft, ChevronRight, Code, Command, FileText, Figma, Framer, Globe, Inbox, Layers, Lock,
        LogOut, Mail, Plus, Scissors, Send, Settings, Shield, Star, Type, Users, Zap,
        Github, BarChart3, Pencil, CirclePlay, Sparkles, Rocket, Gauge, Workflow,
        BadgeCheck, TrendingUp, Menu, Briefcase, GraduationCap, Package, Target,
        BookOpen, MessageCircle, Calendar, CircleCheck, Quote, PlugZap, Phone,
        MapPin, Clock, Building2,
      } from 'lucide';
      createIcons({
        icons: {
          ArrowRight, ArrowUpRight, ArrowLeft, Folder, Cpu, Aperture, Check, ChevronDown,
          ChevronLeft, ChevronRight, Code, Command, FileText, Figma, Framer, Globe, Inbox, Layers, Lock,
          LogOut, Mail, Plus, Scissors, Send, Settings, Shield, Star, Type, Users, Zap,
          Github, BarChart3, Pencil, CirclePlay, Sparkles, Rocket, Gauge, Workflow,
          BadgeCheck, TrendingUp,
        },
      });
    </script>
  </body>
</html>
