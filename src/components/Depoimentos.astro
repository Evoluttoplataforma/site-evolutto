---
// Grid de depoimentos com avatar (foto mapeada pelo nome).
interface Item { q: string; n: string; e: string; }
interface Props {
  items: Item[];
  eyebrow?: string;
  title?: string;
  subtitle?: string;
}
const { items, eyebrow = 'Cases', title = 'Consultores que já atendem dezenas de clientes simultaneamente.', subtitle = 'De 1 para 60 clientes por consultor.' } = Astro.props;

const avatares: Record<string, string> = {
  'Afonso Flatin': '/img/avatars/afonso.jpg',
  'André de Souza Machado': '/img/avatars/andre.jpg',
  'Gui David': '/img/avatars/gui.jpg',
  'Heidy Milan': '/img/avatars/heidy.jpg',
  'Kelly Nunes': '/img/avatars/kelly.jpg',
  'Luciano Zorzal': '/img/avatars/luciano.jpg',
  'Rogério Menossi': '/img/avatars/rogerio.jpg',
};
---

<section id="cases" class="py-20 lg:py-28 bg-[#F3F3F1] border-y border-gray-200">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="max-w-3xl mb-14">
      <span class="text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-gray-400">{eyebrow}</span>
      <h2 class="text-3xl lg:text-5xl font-bold tracking-tight text-gray-900 mt-4 mb-5 leading-tight">{title}</h2>
      <p class="text-lg text-gray-500">{subtitle}</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map((d) => (
        <figure class="bg-white rounded-[2rem] p-7 border border-gray-200 shadow-sm flex flex-col">
          <i class="w-7 h-7 text-evolutto-blue/30 mb-4" data-lucide="quote"></i>
          <blockquote class="text-[15px] text-gray-700 leading-relaxed flex-1">{d.q}</blockquote>
          <figcaption class="mt-6 pt-5 border-t border-gray-100 flex items-center gap-3">
            {avatares[d.n] ? (
              <img src={avatares[d.n]} alt={d.n} class="w-11 h-11 rounded-full object-cover border border-gray-200" loading="lazy" />
            ) : (
              <span class="w-11 h-11 rounded-full bg-evolutto-gradient shrink-0"></span>
            )}
            <span>
              <span class="block text-sm font-semibold text-gray-900">{d.n}</span>
              <span class="block text-xs text-gray-400">{d.e}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
