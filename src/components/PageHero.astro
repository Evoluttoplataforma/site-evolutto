---
// Hero de página interna — layout estilo Templum (full-bleed, esquerda, banner + overlay).
interface Props {
  eyebrow?: string;
  titleStart: string;
  accent: string;
  titleEnd?: string;
  text?: string;
  checklist?: string[];
  primaryLabel?: string;
  primaryHref?: string;
  primaryTally?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  image?: string;
  imageFramed?: boolean;
}
const {
  eyebrow, titleStart, accent, titleEnd = '', text, checklist,
  primaryLabel = 'Solicite uma Demonstração', primaryHref = '/#cta', primaryTally,
  secondaryLabel = 'Ver cases', secondaryHref = '/#cases', image, imageFramed = true,
} = Astro.props;
const tallyAttrs = primaryTally
  ? { 'data-tally-open': primaryTally, 'data-tally-layout': 'modal', 'data-tally-hide-title': '1' }
  : {};
---

<section class="relative bg-evolutto-black text-white overflow-hidden min-h-[520px] flex items-center">
  <div class="absolute inset-0">
    <div class="absolute right-0 top-0 bottom-0 w-[60%] bg-evolutto-gradient"></div>
    <div class="absolute top-[20%] right-[18%] w-[420px] h-[420px] bg-evolutto-blue/35 blur-[120px] rounded-full"></div>
    <div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 22px 22px;"></div>
    {image && imageFramed && (
      <div class="hidden lg:block absolute right-[4%] top-1/2 -translate-y-1/2 w-[40%] max-w-[540px]">
        <div class="absolute -inset-5 bg-evolutto-blue/20 rounded-[2.5rem] blur-[70px]"></div>
        <img src={image} alt="" aria-hidden="true" class="relative w-full rounded-[1.5rem] shadow-2xl border border-white/15 object-cover" />
      </div>
    )}
    {image && !imageFramed && (
      <img src={image} alt="" aria-hidden="true" class="hidden lg:block absolute right-[2%] top-1/2 -translate-y-1/2 w-[44%] max-w-[600px] drop-shadow-2xl" />
    )}
  </div>
  <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(100deg, #1b1b1b 0%, #1b1b1b 30%, rgba(27,27,27,0.82) 47%, rgba(27,27,27,0.4) 65%, rgba(27,27,27,0.08) 84%, transparent 100%), radial-gradient(700px 420px at 14% 30%, rgba(51,99,255,0.26), transparent 60%);"></div>

  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-6 py-16">
    <div class="max-w-[640px]">
      {eyebrow && <span class="inline-block text-[12px] font-bold uppercase tracking-[0.16em] text-evolutto-blue mb-5">{eyebrow}</span>}
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tighter leading-[1.05] mb-6" style="text-shadow: 0 2px 24px rgba(0,0,0,0.4)">
        {titleStart}<em class="not-italic text-evolutto-blue">{accent}</em>{titleEnd}
      </h1>
      {text && <p class="text-lg text-gray-300 leading-relaxed mb-8 max-w-xl">{text}</p>}
      {checklist && (
        <ul class="flex flex-col gap-3 mb-8">
          {checklist.map((c) => (
            <li class="flex items-start gap-3 text-[15px] text-gray-200 leading-snug">
              <span class="w-6 h-6 min-w-6 rounded-full bg-evolutto-blue grid place-items-center mt-0.5"><i class="w-3.5 h-3.5 text-white" data-lucide="check"></i></span>
              {c}
            </li>
          ))}
        </ul>
      )}
      <div class="flex flex-wrap gap-3">
        <a class="inline-flex items-center gap-2 bg-evolutto-blue text-white text-sm font-bold px-8 py-4 rounded-full hover:brightness-110 hover:scale-105 transition-all shadow-lg shadow-evolutto-blue/40" href={primaryTally ? '#' : primaryHref} {...tallyAttrs}>{primaryLabel} <i class="w-4 h-4" data-lucide="arrow-right"></i></a>
        {secondaryLabel && <a class="inline-flex items-center gap-2 bg-white/5 border border-white/20 text-white text-sm font-semibold px-8 py-4 rounded-full hover:bg-white/10 transition-colors" href={secondaryHref}><i class="w-4 h-4" data-lucide="circle-play"></i> {secondaryLabel}</a>}
      </div>
    </div>
  </div>
</section>
